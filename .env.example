APP_ENV=development
APP_PORT=8080
AUTO_APPLY_MIGRATIONS=true
MIGRATIONS_DIR=migrations

# Dev-only admin bootstrap. Keep disabled in production.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=admin12345

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=soundmarket
POSTGRES_USER=soundmarket
POSTGRES_PASSWORD=soundmarket
POSTGRES_SSLMODE=disable

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change-me
JWT_TTL=24h

# mock for local fallback, yookassa for test provider flow
PAYMENT_PROVIDER=mock

S3_ENDPOINT=https://s3.timeweb.cloud
S3_REGION=ru-1
S3_BUCKET=soundmarket-dev
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_USE_SSL=true
S3_FORCE_PATH_STYLE=true
SIGNED_URL_TTL=15m

YOOKASSA_SHOP_ID=test-shop
YOOKASSA_SECRET_KEY=test-secret
YOOKASSA_RETURN_URL=http://localhost:3000/payments/return

# Dev-only payment sync stays available outside production through POST /api/v1/payments/sync

MAX_UPLOAD_SIZE=104857600
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,aac
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp

WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024
PREVIEW_DURATION_SECONDS=60
